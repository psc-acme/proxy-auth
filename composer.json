{
    "name": "psc-acme/proxy-auth",
    "description": "Package proxy-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProxyAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "guzzlehttp/psr7": "^2.0",
        "symfony/validator": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/string": "^7.0",
        "symfony/symfony": "^6.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}